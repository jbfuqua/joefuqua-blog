---
import BaseLayout from './BaseLayout.astro';
import { getCollection } from 'astro:content';

interface Props {
  title: string;
  date: string;
  category: string;
  excerpt?: string;
  issue?: number;
  source?: string;
  currentPath?: string;
}

const { title, date, category, excerpt, issue, source, currentPath } = Astro.props;

const formattedDate = new Date(date).toLocaleDateString('en-US', {
  year: 'numeric', month: 'long', day: 'numeric'
});

const categoryLabels: Record<string, string> = {
  'governance': 'Governance & Control',
  'futures': 'Futures & Long Arc',
  'technology-society': 'Technology & Society',
  'algorithm-and-blues': 'Algorithm & Blues',
};

const categoryLabel = categoryLabels[category] ?? category;

const eyebrow = issue
  ? `Algorithm & Blues · #${issue}`
  : categoryLabel;

const articles = await getCollection('articles');
const related = articles
  .filter(a => a.data.category === category && (a.data.slug || a.id) !== currentPath?.replace('/writing/', ''))
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 3);
---

<BaseLayout title={title} description={excerpt} currentPath={currentPath}>
  <article>
    <div class="article-header">
      <div class="article-eyebrow">{eyebrow}</div>
      <h1 class="article-title">{title}</h1>
      <div class="article-meta">
        <span>{formattedDate}</span>
        {source === 'linkedin' && (
          <>
            <span class="meta-dot"></span>
            <span>Originally on LinkedIn</span>
          </>
        )}
      </div>
    </div>

    <div class="prose">
      <slot />
    </div>

    {related.length > 0 && (
      <div class="related-section">
        <div class="related-header">More in {categoryLabel}</div>
        {related.map(post => (
          <a href={`/writing/${post.data.slug || post.id}`} class="related-link">
            {post.data.title}
          </a>
        ))}
      </div>
    )}

    <div style="max-width: var(--article-width); margin: 0 auto; padding: 0 clamp(1.5rem, 5vw, 5rem) 3rem;">
      <a href="/writing" style="font-family: var(--font-mono); font-size: 0.65rem; letter-spacing: 0.1em; text-transform: uppercase; color: var(--ink-light);">
        ← All Writing
      </a>
    </div>
  </article>
</BaseLayout>

<style>
  .related-section {
    max-width: var(--article-width);
    margin: 0 auto;
    padding: 0 clamp(1.5rem, 5vw, 5rem) 2.5rem;
    border-top: 1px solid var(--paper-rule);
    padding-top: 2rem;
  }

  .related-header {
    font-family: var(--font-mono);
    font-size: 0.62rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 1rem;
  }

  .related-link {
    display: block;
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 600;
    color: var(--ink);
    line-height: 1.3;
    padding: 0.65rem 0;
    border-bottom: 1px solid var(--paper-rule);
    transition: color 0.15s;
  }

  .related-link:hover {
    color: var(--accent);
  }
</style>
