---
import '../styles/global.css';
import { getCollection } from 'astro:content';
import NewsletterSignup from '../components/NewsletterSignup.astro';
import { getWritingCategoryHref } from '../lib/writing';

interface Props {
  title?: string;
  description?: string;
  currentPath?: string;
  showGlobalSignup?: boolean;
}

const { 
  title = 'Joe Fuqua', 
  description = 'Joe Fuqua has been watching humans panic about intelligent machines since 1988. He writes about the longer arc — why the panic is usually wrong, how governance becomes the actual competitive advantage, and what it takes to build organizations that are ready for what comes next.',
  currentPath = '',
  showGlobalSignup = !currentPath.startsWith('/writing/') && !currentPath.startsWith('/algorithm-and-blues/')
} = Astro.props;

const anb = await getCollection('anb');
const publishedAnbCount = anb.filter((issue) => issue.data.draft !== true).length;

const sharedNavLinks = [
  { href: 'https://joefuqua.com', label: 'Home', key: 'home' },
  { href: 'https://joefuqua.blog', label: 'Writing', key: 'writing' },
  { href: 'https://joefuqua.art', label: 'Art', key: 'art' },
  { href: 'https://joefuqua.com/about', label: 'About', key: 'about' },
  { href: 'https://joefuqua.blog/algorithm-and-blues#subscribe', label: 'Subscribe', key: 'subscribe' },
];

const socialLinks = [
  { href: 'https://linkedin.com/in/joefuqua', label: 'LinkedIn' },
  { href: 'https://instagram.com/a.nod.tothe.odd', label: 'Instagram' },
];

const sharedActiveKey = currentPath === '/'
  ? 'writing'
  : currentPath === '/about'
    ? 'about'
    : currentPath.startsWith('/algorithm-and-blues')
      ? 'subscribe'
      : currentPath.startsWith('/writing')
        ? 'writing'
        : '';
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title === 'Joe Fuqua' ? title : `${title} — Joe Fuqua`}</title>
  <link rel="canonical" href={`https://joefuqua.blog${currentPath}`} />
  <link rel="sitemap" href="/sitemap-index.xml" />
</head>
<body>
  <div class="site-shell">
    <header class="ecosystem-bar">
      <div class="ecosystem-inner">
        <a href="https://joefuqua.com" class="ecosystem-brand">Joe Fuqua</a>
        <button
          class="ecosystem-toggle"
          type="button"
          aria-expanded="false"
          aria-controls="ecosystem-nav"
        >
          Menu
        </button>
        <nav id="ecosystem-nav" class="ecosystem-nav" aria-label="Cross-site">
          {sharedNavLinks.map((link) => (
            <a
              href={link.href}
              class:list={['ecosystem-link', link.key === 'subscribe' && 'ecosystem-link-subscribe']}
              aria-current={link.key === sharedActiveKey ? 'page' : undefined}
            >
              {link.label}
            </a>
          ))}
        </nav>
      </div>
    </header>

  <header class="masthead">
    <div class="masthead-top">
      <a href="/" class="site-name">Joe <span>Fuqua</span></a>
      <div class="masthead-meta">
        Intelligent Automation Architecture Strategy &amp; Governance<br/>
        Algorithm &amp; Blues · Weekly<br/>
        Charlotte, NC · Est. 1988
      </div>
    </div>
    <nav class="nav">
      <a href="/writing" class={currentPath.startsWith('/writing') ? 'active' : ''}>Writing</a>
      <a href={getWritingCategoryHref('governance')} class={currentPath.includes('/writing/category/governance') ? 'active' : ''}>Governance</a>
      <a href={getWritingCategoryHref('futures')} class={currentPath.includes('/writing/category/futures') ? 'active' : ''}>Futures</a>
      <a href={getWritingCategoryHref('technology-society')} class={currentPath.includes('/writing/category/technology-society') ? 'active' : ''}>Technology &amp; Society</a>
      <a href="/algorithm-and-blues" class={currentPath.startsWith('/algorithm-and-blues') ? 'active' : ''}>Algorithm &amp; Blues</a>
      <a href="/about">About</a>
      <span class="nav-right">
        <a href="/search" class={currentPath === '/search' ? 'active' : ''}>Search</a>
        <a href="/algorithm-and-blues#subscribe" class="nav-subscribe">Subscribe</a>
      </span>
    </nav>
  </header>

  <main class="page-content" data-pagefind-body>
    <slot />
  </main>


  {showGlobalSignup && (
    <section class="newsletter-band">
      <div>
        <div class="newsletter-eyebrow">Algorithm &amp; Blues</div>
        <div class="newsletter-headline">Weekly notes on AI, governance, and the long arc.</div>
        <div class="newsletter-sub">{publishedAnbCount} issues so far.</div>
      </div>
      <div>
        <NewsletterSignup idPrefix="site-subscribe" />
      </div>
    </section>
  )}

  <footer class="site-footer">
    <div class="site-footer-title">
      <strong>Joe Fuqua</strong>
      <span>Writing • Art • Essays on AI</span>
    </div>
    <div class="site-footer-links">
      <a href="https://joefuqua.com">joefuqua.com</a>
      <a href="https://joefuqua.blog">joefuqua.blog</a>
      <a href="https://joefuqua.art">joefuqua.art</a>
      <a href="/rss.xml">RSS</a>
    </div>
    <div class="site-footer-social">
      {socialLinks.map((link) => (
        <a href={link.href} target="_blank" rel="noopener">{link.label}</a>
      ))}
    </div>
  </footer>
  </div>

  <script is:inline>
    const ecosystemToggle = document.querySelector('.ecosystem-toggle');
    const ecosystemNav = document.querySelector('#ecosystem-nav');

    ecosystemToggle?.addEventListener('click', () => {
      const isExpanded = ecosystemToggle.getAttribute('aria-expanded') === 'true';
      ecosystemToggle.setAttribute('aria-expanded', String(!isExpanded));
      ecosystemNav?.classList.toggle('is-open', !isExpanded);
    });
  </script>

</body>
</html>
