---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  currentPath?: string;
}

const { 
  title = 'Joe Fuqua', 
  description = 'Joe Fuqua has been watching humans panic about intelligent machines since 1988. He writes about the longer arc — why the panic is usually wrong, how governance becomes the actual competitive advantage, and what it takes to build organizations that are ready for what comes next.',
  currentPath = ''
} = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title === 'Joe Fuqua' ? title : `${title} — Joe Fuqua`}</title>
  <link rel="canonical" href={`https://joefuqua.blog${currentPath}`} />
  <link rel="sitemap" href="/sitemap-index.xml" />
</head>
<body>

  <header class="masthead">
    <div class="masthead-top">
      <a href="/" class="site-name">Joe <span>Fuqua</span></a>
      <div class="masthead-meta">
        Enterprise AI Governance &amp; Architecture<br/>
        Algorithm &amp; Blues · Weekly<br/>
        Charlotte, NC · Est. 1988
      </div>
    </div>
    <nav class="nav">
      <a href="/writing" class={currentPath.startsWith('/writing') ? 'active' : ''}>Writing</a>
      <a href="/writing?category=governance" class={currentPath.includes('governance') ? 'active' : ''}>Governance</a>
      <a href="/writing?category=futures" class={currentPath.includes('futures') ? 'active' : ''}>Futures</a>
      <a href="/writing?category=technology-society">Technology &amp; Society</a>
      <a href="/algorithm-and-blues" class={currentPath.startsWith('/algorithm-and-blues') ? 'active' : ''}>Algorithm &amp; Blues</a>
      <a href="/about">About</a>
      <span class="nav-right">
        <a href="/algorithm-and-blues#subscribe" class="nav-subscribe">Subscribe</a>
      </span>
    </nav>
  </header>

  <main class="page-content">
    <slot />
  </main>


  <section class="newsletter-band">
    <div>
      <div class="newsletter-eyebrow">Algorithm &amp; Blues · Weekly</div>
      <div class="newsletter-headline">AI research translated into decisions<br/><em>executives can actually make.</em></div>
      <div class="newsletter-sub">43 issues. No hype. No filler. One clear argument per week.</div>
    </div>
    <div>
      <div class="newsletter-form" id="subscribe-form">
        <input type="email" id="subscribe-email" class="newsletter-input" placeholder="your@email.com" />
        <button class="newsletter-btn" id="subscribe-btn">Subscribe</button>
        <span id="subscribe-msg" style="display:none; font-family: var(--font-mono); font-size: 0.65rem; letter-spacing: 0.08em; color: var(--accent-light); padding-left: 1rem;"></span>
      </div>

    <script is:inline>
      console.log('script loaded');
      document.getElementById('subscribe-btn').addEventListener('click', async () => {   
	  console.log('button clicked');    
          const email = document.getElementById('subscribe-email').value.trim();
          const msg = document.getElementById('subscribe-msg');
          const btn = document.getElementById('subscribe-btn');

          if (!email || !email.includes('@')) {
            msg.textContent = 'Please enter a valid email.';
            msg.style.display = 'inline';
            return;
          }

          btn.textContent = 'Subscribing...';
          btn.disabled = true;

          try {
            const res = await fetch('https://beehiiv-subscribe.joe-b-fuqua.workers.dev', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ email }),
            });

            if (res.ok) {
              msg.textContent = "You're in. See you Sunday.";
              msg.style.color = 'var(--accent-light)';
              msg.style.display = 'inline';
              document.getElementById('subscribe-email').value = '';
              btn.style.display = 'none';
            } else {
              msg.textContent = 'Something went wrong. Try again.';
              msg.style.display = 'inline';
              btn.textContent = 'Subscribe';
              btn.disabled = false;
            }
          } catch (e) {
            msg.textContent = 'Something went wrong. Try again.';
            msg.style.display = 'inline';
            btn.textContent = 'Subscribe';
            btn.disabled = false;
          }
        });
      </script>
    </div>
  </section>

  <footer>
    <div class="footer-left">Joe <span>Fuqua</span> · joefuqua.blog</div>
    <div class="footer-links">
      <a href="https://linkedin.com/in/joefuqua" target="_blank" rel="noopener">LinkedIn</a>
      <a href="/algorithm-and-blues">Algorithm &amp; Blues</a>
      <a href="https://contemplations.ai" target="_blank" rel="noopener">contemplations.ai</a>
      <a href="/rss.xml">RSS</a>
    </div>
    <div class="footer-copy">© 2026 Joe Fuqua · Charlotte, NC · Enterprise AI Governance &amp; Architecture · 40 years in technology</div>
  </footer>

</body>
</html>