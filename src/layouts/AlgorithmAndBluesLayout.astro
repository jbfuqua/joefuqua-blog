---
import BaseLayout from './BaseLayout.astro';
import BeehiivSignup from '../components/BeehiivSignup.astro';
import { getCollection } from 'astro:content';

interface Props {
  title: string;
  date: string;
  thesis?: string;
  issue?: number;
  source?: string;
  currentPath?: string;
}

const { title, date, thesis, issue, source, currentPath } = Astro.props;

const formattedDate = new Date(date).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const allIssues = (await getCollection('anb'))
  .sort((a, b) => (a.data.issue ?? 0) - (b.data.issue ?? 0));

const currentIndex = allIssues.findIndex(i => i.data.issue === issue);
const prevIssue = currentIndex > 0 ? allIssues[currentIndex - 1] : null;
const nextIssue = currentIndex < allIssues.length - 1 ? allIssues[currentIndex + 1] : null;
---

<BaseLayout title={title} description={thesis} currentPath={currentPath}>
  <article>
    <div class="article-header">
      <div class="article-eyebrow">Algorithm &amp; Blues</div>
      <h1 class="article-title">{title}</h1>
      {thesis && <p class="anb-thesis">{thesis}</p>}

      <div class="anb-meta-block">
        <div class="anb-meta-item">
          <span class="anb-meta-label">Issue</span>
          <span class="anb-meta-value">#{issue ?? '—'}</span>
        </div>
        <div class="anb-meta-item">
          <span class="anb-meta-label">Published</span>
          <span class="anb-meta-value">{formattedDate}</span>
        </div>
        <div class="anb-meta-item">
          <span class="anb-meta-label">Series</span>
          <span class="anb-meta-value">Weekly publication</span>
        </div>
        {source && (
          <div class="anb-meta-item">
            <span class="anb-meta-label">Source</span>
            <span class="anb-meta-value">{source === 'linkedin' ? 'Originally on LinkedIn' : 'Original'}</span>
          </div>
        )}
      </div>
    </div>

    <div class="prose">
      <slot />
    </div>

    <div class="anb-subscribe-wrap">
      <BeehiivSignup
        idPrefix={`anb-issue-${issue ?? 'latest'}`}
        title="Get the next issue in your inbox"
        blurb="Algorithm & Blues publishes one clear argument per week on AI research, governance, and the long arc."
        eyebrow="Subscribe"
      />
    </div>

    {(prevIssue || nextIssue) && (
      <div class="anb-prev-next">
        {prevIssue ? (
          <a href={`/algorithm-and-blues/${prevIssue.data.slug || prevIssue.id}`} class="anb-pn-link">
            <span class="anb-pn-label">← Previous Issue</span>
            <span class="anb-pn-title">#{prevIssue.data.issue} · {prevIssue.data.title}</span>
          </a>
        ) : <span />}
        {nextIssue ? (
          <a href={`/algorithm-and-blues/${nextIssue.data.slug || nextIssue.id}`} class="anb-pn-link anb-pn-next">
            <span class="anb-pn-label">Next Issue →</span>
            <span class="anb-pn-title">#{nextIssue.data.issue} · {nextIssue.data.title}</span>
          </a>
        ) : <span />}
      </div>
    )}

    <div class="anb-links">
      <a href="/algorithm-and-blues" class="anb-link">← Publication Home</a>
      <a href="/algorithm-and-blues/archive" class="anb-link">Browse Archive</a>
    </div>
  </article>
</BaseLayout>

<style>
  .anb-thesis {
    font-size: 1.05rem;
    line-height: 1.8;
    color: var(--ink-mid);
    max-width: 60ch;
    margin-top: 1.25rem;
  }

  .anb-meta-block {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.85rem 1rem;
    max-width: var(--article-width);
    margin: 1.5rem auto 0;
    padding: 1rem clamp(1.5rem, 5vw, 5rem);
    border-top: 1px solid var(--paper-rule);
    border-bottom: 1px solid var(--paper-rule);
  }

  .anb-meta-item {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }

  .anb-meta-label,
  .anb-link {
    font-family: var(--font-mono);
    font-size: 0.62rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .anb-meta-label {
    color: var(--ink-light);
  }

  .anb-meta-value {
    color: var(--ink);
  }

  .anb-subscribe-wrap {
    max-width: var(--article-width);
    margin: 0 auto;
    padding: 0 clamp(1.5rem, 5vw, 5rem) 2.5rem;
  }

  .anb-links {
    max-width: var(--article-width);
    margin: 0 auto;
    padding: 0 clamp(1.5rem, 5vw, 5rem) 3rem;
    display: flex;
    justify-content: space-between;
    gap: 1rem;
  }

  .anb-link {
    color: var(--ink-light);
  }

  .anb-prev-next {
    max-width: var(--article-width);
    margin: 0 auto;
    padding: 0 clamp(1.5rem, 5vw, 5rem) 2rem;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
    border-top: 1px solid var(--paper-rule);
    padding-top: 1.5rem;
  }

  .anb-pn-link {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    text-decoration: none;
  }

  .anb-pn-next {
    text-align: right;
  }

  .anb-pn-label {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ink-light);
  }

  .anb-pn-title {
    font-family: var(--font-display);
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--ink);
    line-height: 1.3;
    transition: color 0.15s;
  }

  .anb-pn-link:hover .anb-pn-title {
    color: var(--accent);
  }

  @media (max-width: 720px) {
    .anb-meta-block {
      grid-template-columns: 1fr;
    }

    .anb-links {
      flex-direction: column;
    }

    .anb-prev-next {
      grid-template-columns: 1fr;
    }

    .anb-pn-next {
      text-align: left;
    }
  }
</style>
