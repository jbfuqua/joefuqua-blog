---
import { getCollection } from 'astro:content';
import AlgorithmAndBluesLayout from '../../layouts/AlgorithmAndBluesLayout.astro';

export async function getStaticPaths() {
  const anb = await getCollection('anb');
  return anb.map(post => ({
    params: { slug: post.data.slug || post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();
---

<AlgorithmAndBluesLayout
  title={post.data.title}
  date={post.data.date}
  thesis={post.data.excerpt}
  issue={post.data.issue}
  source={post.data.source}
  currentPath={`/algorithm-and-blues/${post.data.slug || post.slug}`}
>
  <Content />
</AlgorithmAndBluesLayout>
