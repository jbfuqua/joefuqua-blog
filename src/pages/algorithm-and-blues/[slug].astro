---
import { getCollection, render } from 'astro:content';
import AlgorithmAndBluesLayout from '../../layouts/AlgorithmAndBluesLayout.astro';

export async function getStaticPaths() {
  const anb = await getCollection('anb');
  return anb.map(post => ({
    params: { slug: post.data.slug || post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<AlgorithmAndBluesLayout
  title={post.data.title}
  date={post.data.date}
  thesis={post.data.excerpt}
  issue={post.data.issue}
  source={post.data.source}
  currentPath={`/algorithm-and-blues/${post.data.slug || post.id}`}
>
  <Content />
</AlgorithmAndBluesLayout>
