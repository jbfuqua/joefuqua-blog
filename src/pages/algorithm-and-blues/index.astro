---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BeehiivSignup from '../../components/BeehiivSignup.astro';
import { getCollection } from 'astro:content';

const anb = await getCollection('anb');
const sorted = anb.sort((a, b) => (b.data.issue ?? 0) - (a.data.issue ?? 0));

const [latestIssue, ...olderIssues] = sorted;
const recentIssues = olderIssues.slice(0, 3);

function formatDate(d: string) {
  return new Date(d).toLocaleDateString('en-US', {
    year: 'numeric', month: 'short', day: 'numeric'
  });
}
---
<BaseLayout title="Algorithm & Blues" currentPath="/algorithm-and-blues" ogImage="https://joefuqua.blog/og-algorithm-and-blues.png">
  <section class="anb-landing">
    <div class="anb-landing-copy">
      <div class="article-eyebrow">Weekly Publication</div>
      <h1 class="article-title" style="margin-bottom: 1rem;">Algorithm &amp; Blues</h1>
      <p class="anb-landing-lede">
        AI research translated into decisions executives can actually make. One clear argument per issue, published weekly.
      </p>
      <div class="anb-landing-links">
        <a href={latestIssue ? `/algorithm-and-blues/${latestIssue.data.slug || latestIssue.id}` : '/algorithm-and-blues/archive'} class="anb-landing-primary">
          Read Latest Issue
        </a>
        <a href="/algorithm-and-blues/archive" class="anb-landing-secondary">Browse Archive</a>
      </div>
    </div>

    <div id="subscribe">
      <BeehiivSignup
        idPrefix="anb-home"
        title="Get the weekly issue"
        blurb="Published every Sunday since May 2025. No hype, no filler, one clear argument per issue."
      />
    </div>
  </section>

  {latestIssue && (
    <>
      <div class="section-divider" style="margin-top: 3rem;">
        <div class="section-divider-inner">
          <span class="section-title">Latest Issue</span>
          <span class="section-rule"></span>
          <span style="font-family: var(--font-mono); font-size: 0.6rem; color: var(--ink-faint);">#{latestIssue.data.issue}</span>
        </div>
      </div>

      <section class="anb-feature">
        <div class="anb-feature-meta">
          <div class="anb-feature-issue">Issue #{latestIssue.data.issue}</div>
          <div>{formatDate(latestIssue.data.date)}</div>
        </div>
        <div class="anb-feature-body">
          <a href={`/algorithm-and-blues/${latestIssue.data.slug || latestIssue.id}`}>
            <h2 class="card-title">{latestIssue.data.title}</h2>
          </a>
          {latestIssue.data.excerpt && (
            <p class="card-excerpt" style="max-width: 56ch;">{latestIssue.data.excerpt}</p>
          )}
        </div>
      </section>
    </>
  )}

  <div class="section-divider" style="margin-top: 3rem;">
    <div class="section-divider-inner">
      <span class="section-title">Recent Issues</span>
      <span class="section-rule"></span>
      <a href="/algorithm-and-blues/archive" class="section-link">Full Archive →</a>
    </div>
  </div>

  <div class="article-list">
    {recentIssues.map(post => (
      <div class="article-card">
        <div class="card-date">
          <div style="font-family: var(--font-mono); font-size: 0.7rem; color: var(--accent); font-weight: 600;">#{post.data.issue}</div>
          <div style="margin-top: 0.25rem;">{formatDate(post.data.date)}</div>
        </div>
        <div class="card-body">
          <a href={`/algorithm-and-blues/${post.data.slug || post.id}`}>
            <div class="card-title">{post.data.title}</div>
          </a>
          {post.data.excerpt && (
            <p class="card-excerpt">{post.data.excerpt}</p>
          )}
        </div>
      </div>
    ))}
  </div>
</BaseLayout>

<style>
  .anb-landing {
    max-width: 1200px;
    margin: 0 auto;
    padding: 3rem clamp(1.5rem, 5vw, 5rem) 0;
    display: grid;
    grid-template-columns: minmax(0, 1.2fr) minmax(320px, 0.8fr);
    gap: 2rem;
    align-items: start;
  }

  .anb-landing-lede {
    font-size: 1.05rem;
    color: var(--ink-mid);
    line-height: 1.8;
    max-width: 56ch;
  }

  .anb-landing-links {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    margin-top: 1.5rem;
  }

  .anb-landing-primary,
  .anb-landing-secondary,
  .anb-feature-issue {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .anb-landing-primary {
    background: var(--ink);
    color: var(--paper);
    padding: 0.7rem 1rem;
  }

  .anb-landing-secondary {
    border: 1px solid var(--paper-rule);
    color: var(--ink-mid);
    padding: 0.7rem 1rem;
  }

  .anb-feature {
    display: grid;
    grid-template-columns: 180px 1fr;
    gap: 1.5rem;
    padding: 1.5rem clamp(1.5rem, 5vw, 5rem) 0;
  }

  .anb-feature-meta {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--ink-light);
  }

  .anb-feature-issue {
    color: var(--accent);
    margin-bottom: 0.4rem;
  }

  @media (max-width: 900px) {
    .anb-landing,
    .anb-feature {
      grid-template-columns: 1fr;
    }
  }
</style>
