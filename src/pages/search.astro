---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Search" currentPath="/search">
  <div style="max-width: 720px; margin: 0 auto; padding: 3rem clamp(1.5rem, 5vw, 5rem) 4rem;">
    <div class="article-eyebrow">Search</div>
    <h1 class="article-title" style="margin-bottom: 2rem;">Find Articles</h1>
    <link href="/pagefind/pagefind-ui.css" rel="stylesheet" />
    <div id="search"></div>
  </div>

  <style is:global>
    :root {
      --pagefind-ui-scale: 0.9;
      --pagefind-ui-primary: var(--accent, #9a7c2e);
      --pagefind-ui-text: var(--ink, #141820);
      --pagefind-ui-background: var(--paper, #eef0f4);
      --pagefind-ui-border: var(--paper-rule, #cdd1dc);
      --pagefind-ui-tag: var(--paper-warm, #e4e7ee);
      --pagefind-ui-border-width: 1px;
      --pagefind-ui-border-radius: 0;
      --pagefind-ui-font: var(--font-body, 'Libre Baskerville', serif);
    }

    .pagefind-ui__search-input {
      font-family: var(--font-body, 'Libre Baskerville', serif) !important;
    }

    .pagefind-ui__result-title {
      font-family: var(--font-display, 'Raleway', sans-serif) !important;
      font-weight: 600 !important;
    }

    .pagefind-ui__result-link {
      color: var(--ink, #141820) !important;
    }

    .pagefind-ui__result-link:hover {
      color: var(--accent, #9a7c2e) !important;
    }

    .pagefind-ui__result-excerpt {
      font-size: 0.9rem !important;
      color: var(--ink-mid, #2e3444) !important;
      line-height: 1.7 !important;
    }
  </style>

  <script is:inline>
    (function() {
      var pagefindPath = '/pagefind/pagefind-ui.js';
      import(pagefindPath).then(function(module) {
        new module.PagefindUI({
          element: '#search',
          showSubResults: true,
          showImages: false,
        });
      });
    })();
  </script>
</BaseLayout>
